        </div>

        <div class="dashboard-grid">
          ${metricCard('พฤติกรรมกายดีเฉลี่ย', valueOrDash(summary.avgS2Positive, ' / 7'), 's2_positive_count', 'teal')}
          ${metricCard('จิตวิญญาณดีเฉลี่ย', valueOrDash(summary.avgS6Positive, ' / 12'), 's6_positive_count', 'coral')}
          ${metricCard('ความครบถ้วนข้อมูล', numberText(summary.completenessPct || 0) + '%', 'ตามตัวแปรที่ไม่ใช่สูตร', 'sun')}
          ${metricCard('ข้อมูลล่าสุด', summary.latestDate ? escapeHtml(summary.latestDate) : '-', 'วันที่บันทึกล่าสุด', 'leaf')}
