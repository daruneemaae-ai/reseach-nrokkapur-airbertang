    function filterDictionary() {
      const query = String(document.getElementById('dictionarySearch').value || '').trim().toLowerCase();
      document.querySelectorAll('[data-dictionary-row]').forEach((row) => {
        row.style.display = row.dataset.search.includes(query) ? '' : 'none';
      });
    }

    function setStatus(message, type) {
      const status = document.getElementById('syncStatus');
      const text = document.getElementById('syncText');
      status.className = 'status-pill' + (type === 'ok' ? ' ok' : type === 'error' ? ' error' : '');
      text.textContent = message;
    }

    function emptySummary() {
      return {
        totalResponses: 0,
        todayResponses: 0,
        avgAgeYears: 0,
        avgBmi: 0,
        avgS2Positive: 0,
        avgS6Positive: 0,
        completenessPct: 0,
        distributions: {},
        risk: {},
        recentRecords: []
      };
    }

    function normalizeType(field) {
      return String(field.normalizedType || field.type || 'text').toLowerCase();
    }

    function isFrequent(value) {
      const text = String(value || '').trim();
      return text === 'ทุกวัน' || text.indexOf('บ่อย') === 0;
    }

    function binaryGroupKey(field) {
      return [field.section || '', field.item || '', field.note || ''].join('|');
    }

    function binaryGroupTitle(group) {
      const first = group[0] || {};
      if (first.item && !/^\d+$/.test(String(first.item))) return first.item;

      const prefix = commonPrefix(group.map((field) => String(field.label || '').split(':')[0].trim()).filter(Boolean));
      if (prefix) return prefix;

      return 'เลือกได้หลายข้อ';
    }

    function shortBinaryLabel(label) {
      const text = String(label || '');
      if (text.indexOf(':') !== -1) return text.split(':').slice(1).join(':').trim();
      return text;
    }

    function commonPrefix(values) {
      if (!values.length) return '';
      let prefix = values[0];
      for (let i = 1; i < values.length; i++) {
        while (values[i].indexOf(prefix) !== 0 && prefix) {
          prefix = prefix.slice(0, -1);
        }
      }
      return prefix.trim();
    }

    function shortSectionName(section) {
      return String(section || '').replace('ส่วนที่ ', '').replace('สุขภาวะ', '').trim();
    }

    function shouldUseTextarea(field) {
      const name = String(field.name || '');
      const label = String(field.label || '');
      return name.indexOf('suggestions') !== -1
        || name.indexOf('concern') !== -1
        || label.indexOf('ข้อเสนอแนะ') !== -1
        || label.indexOf('กังวล') !== -1;
    }

    function shouldUseFullWidth(field) {
      return shouldUseTextarea(field) || String(field.label || '').length > 74;
    }

    function numberAttrs(name) {
      if (name === 'age_month') return 'min="0" max="11"';
      if (name === 'age_year') return 'min="0" max="25"';
      if (name === 'mobile_hours_per_day') return 'min="0" max="24"';
      if (name === 'weight_kg' || name === 'height_cm' || name === 'family_members' || name === 'sweet_shop_count') return 'min="0"';
      return '';
    }

    function todayInputValue() {
      const now = new Date();
      const y = now.getFullYear();
      const m = String(now.getMonth() + 1).padStart(2, '0');
      const d = String(now.getDate()).padStart(2, '0');
      return `${y}-${m}-${d}`;
    }

    function formatThaiDateTime(value) {
      if (!value) return '';
      const normalized = String(value).replace(/([+-]\d{2})(\d{2})$/, '$1:$2');
      const date = new Date(normalized);
      if (isNaN(date.getTime())) return value;
      return date.toLocaleString('th-TH', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    function valueOrDash(value, suffix) {
      const number = Number(value || 0);
      if (!number) return '-';
      return escapeHtml(numberText(number) + suffix);
    }

    function numberText(value) {
      const number = Number(value || 0);
      return number.toLocaleString('th-TH', { maximumFractionDigits: 1 });
    }

    function escapeHtml(value) {
      return String(value === null || value === undefined ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function escapeAttr(value) {
      return escapeHtml(value).replace(/`/g, '&#96;');
    }
  </script>
</body>
</html>
