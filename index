                    <td>${escapeHtml(record.child_name)}</td>
                    <td>${escapeHtml(record.age_year)}</td>
                    <td>${escapeHtml(record.sex)}</td>
                    <td>${escapeHtml(record.self_nutrition_status)}</td>
                    <td>${escapeHtml(record.s2_positive_count)}</td>
                    <td>${escapeHtml(record.s6_positive_count)}</td>
                  </tr>
