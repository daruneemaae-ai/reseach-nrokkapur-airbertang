        <div class="risk-grid">
          ${renderRiskTiles(summary.risk || {})}
        </div>

        <div class="chart-layout">
          ${renderDistributionPanel('เพศ', 'sex')}
          ${renderDistributionPanel('ภาวะโภชนาการตนเอง', 'self_nutrition_status')}
          ${renderDistributionPanel('ดื่มน้ำต่อวัน', 'water_glasses')}
          ${renderDistributionPanel('ความสนใจเข้าร่วมโครงการ', 'join_youth_health_project')}
        </div>

        <div style="height:16px"></div>
        ${renderRecentTable(summary.recentRecords || [])}
