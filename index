    function renderForm() {
      if (!state.schema) return;

      const sections = state.schema.sections.filter((section) => {
        return fieldsBySection(section).some((field) => !field.computed);
      });

      const formContent = document.getElementById('formContent');
      formContent.innerHTML = `
        <div class="form-layout">
          <aside class="section-nav" id="sectionNav">
            ${sections.map((section, index) => `
              <button type="button" class="section-button ${index === state.activeSectionIndex ? 'active' : ''}" data-section-index="${index}">
                <span class="section-number">${index + 1}</span>
                <span class="section-text">${escapeHtml(shortSectionName(section))}</span>
              </button>
            `).join('')}
          </aside>

          <section class="form-panel">
            <div id="formNotice" class="notice"></div>
            <form id="surveyForm" autocomplete="off">
              ${sections.map((section, index) => `
                <div class="section-panel ${index === state.activeSectionIndex ? 'active' : ''}" data-section-panel="${index}">
                  <div class="section-heading">
                    <h2>${escapeHtml(section)}</h2>
                    <p>${numberText(fieldsBySection(section).filter((field) => !field.computed).length)} ตัวแปรในส่วนนี้</p>
                  </div>
                  <div class="fields-grid">
                    ${renderFields(fieldsBySection(section).filter((field) => !field.computed))}
                  </div>
                </div>
              `).join('')}

              <div class="computed-strip">
                <div class="computed-card">
                  <strong id="liveS2Count">0 / 7</strong>
                  <span>s2_positive_count</span>
                </div>
                <div class="computed-card">
                  <strong id="liveS6Count">0 / 12</strong>
                  <span>s6_positive_count</span>
                </div>
              </div>

              <div class="form-actions">
                <div class="step-actions">
                  <button id="prevSection" class="secondary-button" type="button"><span>‹</span>ก่อนหน้า</button>
                  <button id="nextSection" class="secondary-button" type="button">ถัดไป<span>›</span></button>
                </div>
                <div class="step-actions">
                  <button id="resetForm" class="secondary-button" type="button"><span>↺</span>ล้างฟอร์ม</button>
                  <button id="submitButton" class="primary-button" type="submit"><span>✓</span>บันทึกลง Google Sheet</button>
                </div>
              </div>
            </form>
          </section>
        </div>
      `;

      document.querySelectorAll('[data-section-index]').forEach((button) => {
        button.addEventListener('click', () => switchSection(Number(button.dataset.sectionIndex)));
      });

      document.getElementById('prevSection').addEventListener('click', () => switchSection(state.activeSectionIndex - 1));
      document.getElementById('nextSection').addEventListener('click', () => switchSection(state.activeSectionIndex + 1));
      document.getElementById('resetForm').addEventListener('click', resetSurveyForm);
      document.getElementById('surveyForm').addEventListener('submit', submitSurvey);
      document.getElementById('surveyForm').addEventListener('input', updateComputedPreview);
      document.getElementById('surveyForm').addEventListener('change', updateComputedPreview);

      setDefaultValues();
      updateComputedPreview();
      updateStepButtons();
    }

    function renderFields(fields) {
      let html = '';
      let index = 0;

      while (index < fields.length) {
        const field = fields[index];
        const type = normalizeType(field);

        if (type === 'binary') {
          const groupKey = binaryGroupKey(field);
          const group = [];

          while (index < fields.length && normalizeType(fields[index]) === 'binary' && binaryGroupKey(fields[index]) === groupKey) {
            group.push(fields[index]);
            index++;
          }

          html += renderBinaryGroup(group);
        } else {
          html += renderField(field);
          index++;
        }
      }

      return html;
    }

    function renderField(field) {
      const type = normalizeType(field);
      const full = shouldUseFullWidth(field) ? ' full' : '';
      const note = field.note ? `<div class="field-note">${escapeHtml(field.note)}</div>` : '';

      return `
        <label class="field${full}">
          <span class="field-label">
            ${escapeHtml(field.label || field.name)}
            <span class="field-code">${escapeHtml(field.name)}</span>
          </span>
          ${renderControl(field, type)}
          ${note}
        </label>
      `;
    }

    function renderControl(field, type) {
      const name = escapeAttr(field.name);

      if (type === 'dropdown') {
        const options = (state.schema.options || {})[field.optionKey] || [];
        return `
          <select name="${name}" data-type="dropdown">
            <option value="">เลือกคำตอบ</option>
            ${options.map((option) => `<option value="${escapeAttr(option)}">${escapeHtml(option)}</option>`).join('')}
          </select>
        `;
      }

      if (type === 'date') {
        return `<input name="${name}" type="date" data-type="date">`;
      }

      if (type === 'number') {
        const attrs = numberAttrs(field.name);
        return `<input name="${name}" type="number" inputmode="decimal" step="any" data-type="number" ${attrs}>`;
      }

      if (shouldUseTextarea(field)) {
        return `<textarea name="${name}" data-type="text"></textarea>`;
      }

      return `<input name="${name}" type="text" data-type="text">`;
    }

    function renderBinaryGroup(group) {
      const title = binaryGroupTitle(group);
      return `
        <fieldset class="binary-group">
          <legend class="binary-title">${escapeHtml(title)}</legend>
          <div class="check-grid">
            ${group.map((field) => `
              <label class="check-tile">
                <input type="checkbox" name="${escapeAttr(field.name)}" data-type="binary" value="1">
                <span class="check-label">
                  ${escapeHtml(shortBinaryLabel(field.label))}
                  <span class="field-code">${escapeHtml(field.name)}</span>
                </span>
              </label>
            `).join('')}
          </div>
        </fieldset>
      `;
    }

    function fieldsBySection(section) {
      return (state.schema.fields || []).filter((field) => field.section === section);
    }

    function switchSection(index) {
      const panels = Array.from(document.querySelectorAll('[data-section-panel]'));
      if (!panels.length) return;

      state.activeSectionIndex = Math.max(0, Math.min(index, panels.length - 1));

      document.querySelectorAll('[data-section-index]').forEach((button) => {
        button.classList.toggle('active', Number(button.dataset.sectionIndex) === state.activeSectionIndex);
      });

      panels.forEach((panel) => {
        panel.classList.toggle('active', Number(panel.dataset.sectionPanel) === state.activeSectionIndex);
      });

      updateStepButtons();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function updateStepButtons() {
      const panels = Array.from(document.querySelectorAll('[data-section-panel]'));
      const prev = document.getElementById('prevSection');
      const next = document.getElementById('nextSection');
      if (!prev || !next || !panels.length) return;

      prev.disabled = state.activeSectionIndex <= 0;
      next.disabled = state.activeSectionIndex >= panels.length - 1;
    }

    function setDefaultValues() {
      const form = document.getElementById('surveyForm');
      if (!form) return;

      const dateInput = form.querySelector('[name="survey_date"]');
      if (dateInput && !dateInput.value) dateInput.value = todayInputValue();
    }

    function resetSurveyForm(silent) {
      const form = document.getElementById('surveyForm');
      if (!form) return;

      form.reset();
      setDefaultValues();
      updateComputedPreview();
      if (!silent) setFormNotice('ล้างฟอร์มเรียบร้อย', 'ok');
    }

    function updateComputedPreview() {
      const form = document.getElementById('surveyForm');
      if (!form || !state.schema) return;

      const s2 = countPositiveFromForm(state.schema.s2PositiveFields || []);
      const s6 = countPositiveFromForm(state.schema.s6PositiveFields || []);

      const s2Node = document.getElementById('liveS2Count');
      const s6Node = document.getElementById('liveS6Count');
      if (s2Node) s2Node.textContent = s2 + ' / 7';
      if (s6Node) s6Node.textContent = s6 + ' / 12';
    }

    function countPositiveFromForm(fieldNames) {
      const form = document.getElementById('surveyForm');
      return fieldNames.reduce((count, fieldName) => {
        const input = form.querySelector(`[name="${fieldName}"]`);
        return count + (input && isFrequent(input.value) ? 1 : 0);
      }, 0);
    }

    function submitSurvey(event) {
      event.preventDefault();
      if (state.pendingSubmit) return;

      const payload = collectPayload();
      state.pendingSubmit = true;
      setSubmitBusy(true);
      setFormNotice('กำลังส่งข้อมูลไปยัง Google Sheet', 'ok');

      const bridge = document.getElementById('submitBridge');
      bridge.action = GAS_WEB_APP_URL;
      bridge.innerHTML = '';

      addHidden(bridge, 'action', 'submit');
      addHidden(bridge, 'payload', JSON.stringify(payload));
      addHidden(bridge, 'submittedAt', new Date().toISOString());

      clearTimeout(state.submitTimer);
      state.submitTimer = setTimeout(() => {
        if (!state.pendingSubmit) return;
        finishSubmit({
          ok: false,
          error: 'ส่งข้อมูลนานเกินไป ตรวจสิทธิ์ Web app และลองอีกครั้ง'
        });
      }, 30000);

      bridge.submit();
    }

    function collectPayload() {
      const form = document.getElementById('surveyForm');
      const payload = {};

      (state.schema.fields || []).forEach((field) => {
        if (field.computed) return;

        const input = form.querySelector(`[name="${field.name}"]`);
        const type = normalizeType(field);

        if (!input) {
          payload[field.name] = type === 'binary' ? 0 : '';
          return;
        }

        if (type === 'binary') {
          payload[field.name] = input.checked ? 1 : 0;
        } else {
          payload[field.name] = String(input.value || '').trim();
        }
      });

      payload.s2_positive_count = countPositiveFromForm(state.schema.s2PositiveFields || []);
      payload.s6_positive_count = countPositiveFromForm(state.schema.s6PositiveFields || []);

      return payload;
    }

    function finishSubmit(result) {
      clearTimeout(state.submitTimer);
      clearTimeout(state.submitFallbackTimer);
      state.pendingSubmit = false;
      setSubmitBusy(false);

      if (result && result.ok) {
        const message = result.recordId
          ? `บันทึกเรียบร้อย: ${result.recordId}`
          : (result.message || 'บันทึกข้อมูลเรียบร้อย');

        resetSurveyForm(true);
        setFormNotice(message, 'ok');
        loadDashboard().then(() => setFormNotice(message, 'ok'));
      } else {
        setFormNotice((result && result.error) || 'บันทึกข้อมูลไม่สำเร็จ', 'error');
      }
    }

    function setSubmitBusy(isBusy) {
      const button = document.getElementById('submitButton');
      if (!button) return;

      button.disabled = isBusy;
      button.innerHTML = isBusy ? '<span>…</span>กำลังบันทึก' : '<span>✓</span>บันทึกลง Google Sheet';
    }

    function addHidden(form, name, value) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = name;
      input.value = value;
      form.appendChild(input);
    }

    function setFormNotice(message, type) {
      const notice = document.getElementById('formNotice');
      if (!notice) return;

      notice.textContent = message;
      notice.className = 'notice show' + (type === 'error' ? ' error' : '');
    }

    function renderDictionary() {
