    }

    function metricCard(label, value, sub, colorName) {
      const className = colorName === 'coral' || colorName === 'sun' || colorName === 'leaf' ? colorName : '';
      return `
        <article class="metric-card ${className}">
          <div class="metric-label">${escapeHtml(label)}</div>
          <div class="metric-value">${value}</div>
          <div class="metric-sub">${escapeHtml(sub)}</div>
        </article>
      `;
    }

    function renderRiskTiles(risk) {
      return Object.keys(RISK_LABELS).map((key) => `
        <div class="risk-tile">
          <strong>${numberText(risk[key] || 0)}</strong>
          <span>${escapeHtml(RISK_LABELS[key])}</span>
        </div>
      `).join('');
    }

    function renderDistributionPanel(title, fieldName) {
      const items = ((state.summary || {}).distributions || {})[fieldName] || [];
      const total = items.reduce((sum, item) => sum + Number(item.count || 0), 0);

      return `
        <section class="chart-panel">
          <div class="panel-title">
            <h2>${escapeHtml(title)}</h2>
            <span class="schema-badge">${numberText(total)} ราย</span>
          </div>
          ${items.length ? renderBars(items, total) : '<div class="empty-state">ยังไม่มีข้อมูล</div>'}
        </section>
      `;
    }

    function renderBars(items, total) {
      return `
        <div class="bar-list">
          ${items.map((item, index) => {
            const pct = total ? Math.round((Number(item.count || 0) / total) * 100) : 0;
            const color = COLORS[index % COLORS.length];
            return `
              <div class="bar-row">
                <div class="bar-label">${escapeHtml(item.label)}</div>
                <div class="bar-track"><span class="bar-fill" style="width:${pct}%;background:${color};"></span></div>
                <div class="bar-count">${numberText(item.count)}</div>
              </div>
            `;
          }).join('')}
        </div>
      `;
    }

    function renderRecentTable(records) {
      if (!records.length) {
        return `
          <section class="table-panel">
            <div class="panel-title"><h2>รายการล่าสุด</h2></div>
            <div class="empty-state">ยังไม่มีรายการแบบสอบถามในชีตข้อมูลดิบ</div>
          </section>
        `;
      }

      return `
        <section class="table-panel">
          <div class="panel-title">
            <h2>รายการล่าสุด</h2>
