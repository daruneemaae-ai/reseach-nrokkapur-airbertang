      const content = document.getElementById('dictionaryContent');

      content.innerHTML = `
        <section class="dictionary-panel">
          <div class="panel-title">
            <h2>พจนานุกรมตัวแปร</h2>
          </div>

          <div class="schema-badges">
            <span class="schema-badge">${numberText(state.schema.variableCount)} ตัวแปรทั้งหมด</span>
            <span class="schema-badge">${numberText(state.schema.inputVariableCount)} ตัวแปรสำหรับกรอก</span>
            <span class="schema-badge">${numberText((state.schema.sections || []).length)} ส่วน</span>
          </div>

          <div class="dictionary-tools">
            <input id="dictionarySearch" type="search" placeholder="ค้นหาชื่อตัวแปร คำถาม หรือส่วน">
            <button id="clearSearch" class="secondary-button" type="button"><span>×</span>ล้าง</button>
          </div>

          <div class="table-scroll">
            <table class="dictionary-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>ชื่อตัวแปร</th>
                  <th>คำถาม</th>
