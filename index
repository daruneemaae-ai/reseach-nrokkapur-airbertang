<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Kampung Sihat Dashboard & Input Form</title>
  <style>
    :root {
      --ink: #18313a;
      --muted: #62727a;
      --paper: #ffffff;
      --wash: #f5faf8;
      --line: #d9e6e2;
      --teal: #00a99d;
      --coral: #ff6f61;
      --sun: #ffc845;
      --leaf: #58b368;
      --berry: #8a5cf6;
      --sky: #3aa7ff;
      --danger: #d94841;
      --shadow: 0 12px 28px rgba(24, 49, 58, 0.12);
      --radius: 8px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: var(--wash);
      color: var(--ink);
      font-family: "Segoe UI", Tahoma, sans-serif;
      font-size: 16px;
      line-height: 1.55;
      letter-spacing: 0;
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
      letter-spacing: 0;
    }

    button {
      cursor: pointer;
    }

    .app-shell {
      min-height: 100vh;
    }

    .top-strip {
      height: 8px;
      background: linear-gradient(90deg, var(--teal), var(--sun), var(--coral), var(--leaf), var(--sky));
    }

    .app-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 18px;
      align-items: center;
      padding: 22px clamp(16px, 4vw, 42px);
      background: var(--paper);
      border-bottom: 1px solid var(--line);
    }

    .brand {
      display: flex;
      gap: 14px;
      align-items: center;
      min-width: 0;
    }

    .brand-mark {
      display: grid;
      width: 48px;
      height: 48px;
      place-items: center;
      flex: 0 0 auto;
      border-radius: var(--radius);
      background: conic-gradient(from 210deg, var(--teal), var(--sun), var(--coral), var(--leaf), var(--teal));
      color: white;
      font-weight: 800;
      box-shadow: var(--shadow);
    }

    h1 {
      margin: 0;
      font-size: 1.35rem;
      line-height: 1.25;
    }

    .subtitle {
      margin: 3px 0 0;
      color: var(--muted);
      font-size: 0.94rem;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      max-width: 360px;
      gap: 8px;
      padding: 8px 12px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: #fbfffd;
      color: var(--muted);
      font-size: 0.9rem;
      white-space: normal;
    }

    .status-dot {
      width: 10px;
      height: 10px;
      border-radius: 99px;
      background: var(--sun);
      flex: 0 0 auto;
    }

    .status-pill.ok .status-dot {
      background: var(--leaf);
    }

    .status-pill.error .status-dot {
      background: var(--danger);
    }

    .view-tabs {
      display: flex;
      gap: 8px;
      align-items: center;
      padding: 14px clamp(16px, 4vw, 42px);
      overflow-x: auto;
      border-bottom: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.76);
      backdrop-filter: blur(10px);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .tab-button,
    .icon-button,
    .primary-button,
    .secondary-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 40px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--paper);
      color: var(--ink);
      padding: 8px 12px;
      text-decoration: none;
      transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
    }

    .tab-button:hover,
    .icon-button:hover,
    .primary-button:hover,
    .secondary-button:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 20px rgba(24, 49, 58, 0.10);
    }

    .tab-button.active {
      border-color: transparent;
      background: var(--teal);
      color: white;
    }

    .primary-button {
      border-color: transparent;
      background: var(--coral);
      color: white;
      font-weight: 700;
    }

    .primary-button:disabled,
    .secondary-button:disabled {
      cursor: wait;
      opacity: 0.62;
      transform: none;
      box-shadow: none;
    }

    .secondary-button {
      background: #f8fffc;
    }

    main {
      padding: 24px clamp(16px, 4vw, 42px) 42px;
    }

    .view {
      display: none;
    }

    .view.active {
      display: block;
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-bottom: 18px;
    }

    .metric-card,
    .chart-panel,
    .table-panel,
    .form-panel,
    .dictionary-panel {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: 0 8px 22px rgba(24, 49, 58, 0.08);
    }

    .metric-card {
      position: relative;
      overflow: hidden;
      padding: 16px;
      min-height: 118px;
    }

    .metric-card::before {
      content: "";
      position: absolute;
      inset: 0 auto 0 0;
      width: 7px;
      background: var(--teal);
    }

    .metric-card.coral::before {
      background: var(--coral);
    }

    .metric-card.sun::before {
      background: var(--sun);
    }

    .metric-card.leaf::before {
      background: var(--leaf);
    }

    .metric-label {
      color: var(--muted);
      font-size: 0.88rem;
      margin-bottom: 6px;
    }

    .metric-value {
      font-size: 2rem;
      font-weight: 800;
      line-height: 1.1;
      overflow-wrap: anywhere;
    }

    .metric-sub {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .chart-layout {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
      align-items: start;
    }

    .chart-panel,
    .table-panel,
    .form-panel,
    .dictionary-panel {
      padding: 18px;
    }

    .panel-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    h2,
    h3 {
      margin: 0;
      line-height: 1.25;
    }

    h2 {
      font-size: 1.18rem;
    }

    h3 {
      font-size: 1rem;
    }

    .risk-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 10px;
      margin: 16px 0;
    }

    .risk-tile {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fffdf8;
      padding: 12px;
      min-height: 92px;
    }

    .risk-tile strong {
      display: block;
      color: var(--coral);
      font-size: 1.55rem;
      line-height: 1.1;
      margin-bottom: 4px;
    }

    .risk-tile span {
      color: var(--muted);
      font-size: 0.86rem;
    }

    .bar-list {
      display: grid;
      gap: 10px;
    }

    .bar-row {
      display: grid;
      grid-template-columns: minmax(110px, 1.1fr) minmax(120px, 2fr) 42px;
      gap: 10px;
      align-items: center;
      font-size: 0.9rem;
    }

    .bar-label {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .bar-track {
      height: 12px;
      overflow: hidden;
      border-radius: 99px;
      background: #eaf2ef;
    }

    .bar-fill {
      display: block;
      width: 0%;
      height: 100%;
      border-radius: 99px;
      background: var(--teal);
    }

    .bar-count {
      text-align: right;
      font-weight: 700;
    }

    .empty-state {
      padding: 22px;
      border: 1px dashed var(--line);
      border-radius: var(--radius);
      background: #fbfffd;
      color: var(--muted);
      text-align: center;
    }

    .recent-table,
    .dictionary-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.92rem;
    }

    .table-scroll {
      overflow-x: auto;
    }

    th,
    td {
      padding: 10px 9px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }

    th {
      background: #f2fbf7;
      color: #28525a;
      font-weight: 800;
      white-space: nowrap;
    }

    td {
      min-width: 80px;
    }

    .form-layout {
      display: grid;
      grid-template-columns: 250px minmax(0, 1fr);
      gap: 18px;
      align-items: start;
    }

    .section-nav {
      display: grid;
      gap: 8px;
      position: sticky;
      top: 78px;
    }

    .section-button {
      display: grid;
      grid-template-columns: 30px minmax(0, 1fr);
      gap: 8px;
      align-items: center;
      width: 100%;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--paper);
      color: var(--ink);
      padding: 9px;
      text-align: left;
    }

    .section-button.active {
      border-color: transparent;
      background: #e6f8f5;
      box-shadow: inset 4px 0 0 var(--teal);
      font-weight: 700;
    }

    .section-number {
      display: grid;
      width: 30px;
      height: 30px;
      place-items: center;
      border-radius: 99px;
      background: var(--sun);
      color: #432d00;
      font-weight: 800;
    }

    .section-text {
      min-width: 0;
      overflow-wrap: anywhere;
      font-size: 0.9rem;
    }

    .form-panel {
      min-height: 520px;
    }

    .section-panel {
      display: none;
    }

    .section-panel.active {
      display: block;
    }

    .section-heading {
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 2px solid #ecf5f1;
    }

    .section-heading p {
      margin: 6px 0 0;
      color: var(--muted);
      font-size: 0.92rem;
    }

    .fields-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .field {
      display: grid;
      gap: 7px;
      min-width: 0;
      padding: 12px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #ffffff;
    }

    .field.full {
      grid-column: 1 / -1;
    }

    .field-label {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      align-items: center;
      font-weight: 750;
    }

    .field-code {
      display: inline-flex;
      max-width: 100%;
      border-radius: 999px;
      background: #eef8f5;
      color: #14665e;
      padding: 2px 8px;
      font-size: 0.78rem;
      font-weight: 700;
      overflow-wrap: anywhere;
    }

    .field-note {
      color: var(--muted);
      font-size: 0.84rem;
    }

    input,
    select,
    textarea {
      width: 100%;
      min-height: 42px;
      border: 1px solid #cbd9d5;
      border-radius: var(--radius);
      background: #fbfffd;
      color: var(--ink);
      padding: 9px 10px;
      outline: none;
    }

    textarea {
      min-height: 92px;
      resize: vertical;
    }

    input:focus,
    select:focus,
    textarea:focus {
      border-color: var(--teal);
      box-shadow: 0 0 0 3px rgba(0, 169, 157, 0.16);
    }

    .binary-group {
      grid-column: 1 / -1;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fffefa;
    }

    .binary-title {
      margin: 0 0 10px;
      font-weight: 800;
    }

    .check-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .check-tile {
      display: grid;
      grid-template-columns: 24px minmax(0, 1fr);
      gap: 8px;
      align-items: start;
      padding: 10px;
      border: 1px solid #eadfb9;
      border-radius: var(--radius);
      background: white;
      min-height: 58px;
    }

    .check-tile input {
      width: 20px;
      height: 20px;
      min-height: 20px;
      margin-top: 2px;
      accent-color: var(--coral);
    }

    .check-label {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .form-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
      justify-content: space-between;
      margin-top: 18px;
      padding-top: 14px;
      border-top: 1px solid var(--line);
    }

    .step-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .computed-strip {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
    }

    .computed-card {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #f8fffc;
      padding: 12px;
    }

    .computed-card strong {
      display: block;
      font-size: 1.45rem;
      line-height: 1.15;
      color: var(--teal);
    }

    .computed-card span {
      color: var(--muted);
      font-size: 0.86rem;
    }

    .notice {
      display: none;
      margin-bottom: 14px;
      padding: 11px 12px;
      border-radius: var(--radius);
      border: 1px solid var(--line);
      background: #f3fffa;
      color: #14665e;
      font-weight: 700;
    }

    .notice.show {
      display: block;
    }

    .notice.error {
      background: #fff3f1;
      color: var(--danger);
      border-color: #ffd0cc;
    }

    .dictionary-tools {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 10px;
      margin-bottom: 14px;
    }

    .schema-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 10px 0 14px;
    }

    .schema-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 9px;
      border-radius: 999px;
      background: #eef8f5;
      color: #14665e;
      font-size: 0.88rem;
      font-weight: 700;
    }

    .hidden {
      display: none;
    }

    @media (max-width: 1120px) {
      .dashboard-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .chart-layout,
      .form-layout {
        grid-template-columns: 1fr;
      }

      .section-nav {
        position: static;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .risk-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 720px) {
      .app-header {
        grid-template-columns: 1fr;
      }

      .dashboard-grid,
      .fields-grid,
      .computed-strip,
      .check-grid,
      .section-nav,
      .risk-grid {
        grid-template-columns: 1fr;
      }

      .bar-row {
        grid-template-columns: minmax(0, 1fr) 42px;
      }

      .bar-track {
        grid-column: 1 / -1;
        grid-row: 2;
      }

      .dictionary-tools {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <div class="top-strip"></div>

    <header class="app-header">
      <div class="brand">
        <div class="brand-mark">KS</div>
        <div>
          <h1>Kampung Sihat Dashboard & Input Form</h1>
          <p class="subtitle">แบบเก็บข้อมูลโภชนาการเด็กและเยาวชน วิถีมลายูมุสลิม</p>
        </div>
      </div>

      <div id="syncStatus" class="status-pill">
        <span class="status-dot"></span>
        <span id="syncText">กำลังเตรียมข้อมูล</span>
      </div>
    </header>

    <nav class="view-tabs" aria-label="Main navigation">
      <button class="tab-button active" type="button" data-view="dashboardView"><span>▦</span>ภาพรวม</button>
      <button class="tab-button" type="button" data-view="formView"><span>＋</span>กรอกข้อมูล</button>
      <button class="tab-button" type="button" data-view="dictionaryView"><span>≡</span>ตัวแปร</button>
      <button id="refreshButton" class="icon-button" type="button" title="รีเฟรชข้อมูล"><span>↻</span>รีเฟรช</button>
    </nav>

    <main>
      <section id="dashboardView" class="view active">
        <div id="dashboardContent">
          <div class="empty-state">กำลังโหลด dashboard จาก Google Apps Script</div>
        </div>
      </section>

      <section id="formView" class="view">
        <div id="formContent">
          <div class="empty-state">กำลังโหลดฟอร์มจากชีตรหัสตัวแปร</div>
        </div>
      </section>

      <section id="dictionaryView" class="view">
        <div id="dictionaryContent">
          <div class="empty-state">กำลังโหลดพจนานุกรมตัวแปร</div>
        </div>
      </section>
    </main>
  </div>

  <form id="submitBridge" class="hidden" method="post" target="gasSubmitFrame"></form>
  <iframe id="gasSubmitFrame" name="gasSubmitFrame" class="hidden" title="GAS submit bridge"></iframe>

  <script>
    const GAS_WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbw-ASr5wqB00QYI7trK3CoDB9Us-lMt1b2FeSbJNhXqwOV6b5tLHagnUdyuD6L6sPsi/exec';

    const FIELD_LABELS = {
      sex: 'เพศ',
      education_level: 'ระดับการศึกษา',
      self_nutrition_status: 'ภาวะโภชนาการ',
      water_glasses: 'การดื่มน้ำ',
      sleep_hours: 'การนอน',
      sick_frequency: 'การป่วย',
      daily_happiness: 'ความสุข',
      stress_frequency: 'ความเครียด',
      join_youth_health_project: 'ความสนใจเข้าร่วมโครงการ'
    };

    const RISK_LABELS = {
      sweetDrinkFrequent: 'ดื่มน้ำหวานบ่อย',
      fastFoodFrequent: 'กินฟาสต์ฟู้ดบ่อย',
      screenEatingFrequent: 'กินหน้าจอบ่อย',
      addSaltySauceFrequent: 'เติมเค็มบ่อย',
      lowWater: 'ดื่มน้ำน้อย'
    };

    const COLORS = ['#00a99d', '#ff6f61', '#ffc845', '#58b368', '#3aa7ff', '#8a5cf6', '#f28c28', '#2a9d8f'];

    const state = {
      schema: null,
      summary: null,
      activeSectionIndex: 0,
      pendingSubmit: false,
      submitTimer: null,
      submitFallbackTimer: null
    };

    document.addEventListener('DOMContentLoaded', () => {
      bindShellEvents();
      loadDashboard();
    });

    function bindShellEvents() {
      document.querySelectorAll('[data-view]').forEach((button) => {
        button.addEventListener('click', () => showView(button.dataset.view));
      });

      document.getElementById('refreshButton').addEventListener('click', () => loadDashboard());

      window.addEventListener('message', (event) => {
        const data = event.data || {};
        if (!data || data.source !== 'kampung-sihat-gas') return;
        if (!state.pendingSubmit) return;
        finishSubmit(data.payload || { ok: false, error: 'ไม่ได้รับผลลัพธ์จาก GAS' });
      });

      document.getElementById('gasSubmitFrame').addEventListener('load', () => {
        if (!state.pendingSubmit) return;
        clearTimeout(state.submitFallbackTimer);
        state.submitFallbackTimer = setTimeout(() => {
          if (!state.pendingSubmit) return;
          finishSubmit({
            ok: true,
            message: 'ส่งข้อมูลแล้ว กำลังรีเฟรช dashboard',
            assumed: true
          });
        }, 1600);
      });
    }

    function showView(viewId) {
      document.querySelectorAll('.view').forEach((view) => {
        view.classList.toggle('active', view.id === viewId);
      });

      document.querySelectorAll('.tab-button[data-view]').forEach((button) => {
        button.classList.toggle('active', button.dataset.view === viewId);
      });
    }

    async function loadDashboard() {
      setStatus('กำลังเชื่อมต่อ Google Apps Script', 'loading');

      try {
        const data = await jsonp('dashboard');
        if (!data.ok) throw new Error(data.error || 'โหลดข้อมูลไม่สำเร็จ');

        state.schema = data.schema;
        state.summary = data.summary;

        renderDashboard();
        renderForm();
        renderDictionary();

        setStatus('ซิงก์ล่าสุด ' + formatThaiDateTime(data.generatedAt), 'ok');
      } catch (err) {
        setStatus(err.message || String(err), 'error');
        renderLoadError(err);
      }
    }

    function jsonp(action, params = {}) {
      return new Promise((resolve, reject) => {
        const callbackName = '__kampungSihatCb_' + Date.now() + '_' + Math.floor(Math.random() * 100000);
        const script = document.createElement('script');
        const timeout = setTimeout(() => {
          cleanup();
          reject(new Error('เชื่อมต่อ GAS ไม่สำเร็จ ตรวจ Deployment URL และสิทธิ์การเข้าถึง Web app'));
        }, 20000);

        window[callbackName] = (payload) => {
          cleanup();
          resolve(payload);
        };

        const query = new URLSearchParams(Object.assign({}, params, {
          action,
          callback: callbackName,
          _: Date.now()
        }));

        script.src = GAS_WEB_APP_URL + (GAS_WEB_APP_URL.includes('?') ? '&' : '?') + query.toString();
        script.onerror = () => {
          cleanup();
          reject(new Error('โหลดสคริปต์จาก GAS ไม่ได้'));
        };

        document.head.appendChild(script);

        function cleanup() {
          clearTimeout(timeout);
          delete window[callbackName];
          script.remove();
        }
      });
    }

    function renderLoadError(err) {
      const html = `
        <div class="empty-state">
