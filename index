    function dictionaryRows(fields) {
      return fields.map((field, index) => `
        <tr data-dictionary-row data-search="${escapeAttr([
          field.name,
          field.label,
          field.section,
          field.type,
          field.optionKey
        ].join(' ').toLowerCase())}">
          <td>${index + 1}</td>
          <td><span class="field-code">${escapeHtml(field.name)}</span></td>
